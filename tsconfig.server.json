{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",

    "module": "Node16",
    "moduleResolution": "Node16",

    "target": "ES2020",
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["server/**/*.ts", "lib/**/*.ts"],
  "exclude": ["node_modules"]
}
